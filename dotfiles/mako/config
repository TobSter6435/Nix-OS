# --- Optik (Passend zu deiner dunklen Catppuccin-Taskbar) ---
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#cba6f7
border-size=2
border-radius=8

# --- Schriftart & Layout ---
font=JetBrainsMono Nerd Font 10
width=300
height=100
margin=20
padding=15

# --- Verhalten ---
# Benachrichtigungen verschwinden nach 5 Sekunden (5000 ms)
default-timeout=5000

# Wo sollen sie auftauchen? (top-right, top-center, etc.)
anchor=top-right